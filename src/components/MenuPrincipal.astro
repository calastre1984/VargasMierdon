---
import { Icon } from "astro-icon/components";
---

<section>
	<nav>
		<div>
			<Icon name="icondoc" width="120" height="120" />
		</div>

		<div class="Busqueda">
			<a href="/">Inicio</a>
			<a href="/about-us">Sobre mi</a>
			<a href="/contact">Contacto</a>
			<a href="/blog">Blog</a>
		</div>
	</nav>
</section>

<style>
	/* Estilos para el menú de navegación */
	nav {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		align-items: center;
		background-color: rgb(28, 183, 255);
		padding: 5px 20px;
		font-size: larger;
	}

	div {
		display: flex;
		gap: 20px;
	}

	.Busqueda a {
		color: rgb(255, 255, 255);
		font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
		font-weight: 600;
		text-decoration: none;
		font-size: 25px;
	}
	.Busqueda a:hover {
			font-weight: 1000;
			transition: font-weight 0.3s ease;

	}
	</style>
